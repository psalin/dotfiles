# Enable focus following mouse
wm.gaps.focus_follows_mouse: yes

# Set smaller default gaps
wm.gaps.inner.size: 2
wm.gaps.outer.size: 2

# Prevent gaps increases from overriding regolith help shortcut
wm.binding.inc_gaps: KP_1
wm.binding.dec_gaps: KP_2
wm.binding.inc_gaps_big: Shift+KP_1
wm.binding.dec_gaps_big: Shift+KP_2

# Use modified status bar config
wm.bar.status_config: ~/.config/i3status-rust/config.toml

# Use foot as the default terminal
wm.program.terminal: foot